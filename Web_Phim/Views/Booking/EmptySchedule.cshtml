@{
    ViewBag.Title = "Chưa Có Lịch Chiếu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .empty-state-container {
        min-height: 60vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        background-color: #3b3b98; /* Màu nền tím than đồng bộ */
        color: white;
        text-align: center;
        padding: 20px;
    }

    .empty-icon {
        font-size: 5rem;
        color: #ffeb3b; /* Màu vàng nổi bật */
        margin-bottom: 20px;
        opacity: 0.8;
    }

    .empty-title {
        font-family: 'Impact', sans-serif;
        font-size: 2.5rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 15px;
    }

    .empty-desc {
        font-size: 1.1rem;
        color: #e0e0e0;
        max-width: 500px;
        margin-bottom: 30px;
    }

    .btn-back {
        padding: 10px 30px;
        background-color: #ff5722;
        color: white;
        text-decoration: none;
        border-radius: 25px;
        font-weight: bold;
        transition: all 0.3s;
        border: 2px solid #ff5722;
    }

        .btn-back:hover {
            background-color: transparent;
            color: #ff5722;
            text-decoration: none;
        }
</style>

<div class="empty-state-container">
    <i class="fas fa-film empty-icon"></i>
    <h2 class="empty-title">Rất tiếc!</h2>
    <p class="empty-desc">
        Hiện tại bộ phim này chưa có lịch chiếu nào trong thời gian tới.
        Vui lòng quay lại sau hoặc chọn bộ phim khác nhé!
    </p>
    <a href="@Url.Action("TrangChu", "Home")" class="btn-back">
        <i class="fas fa-arrow-left"></i> Quay Về Trang Chủ
    </a>
</div>