@model Web_Phim.Models.MovieBookingViewModel
@{
    ViewBag.Title = "Lịch Chiếu - " + Model.TenPhim;
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Lấy ngày đầu tiên để active mặc định
    var firstDateKey = Model.CacNgayChieu.FirstOrDefault().ToString("ddMMyyyy");
}

<style>
    .booking-container {
        background-color: #3b3b98;
        color: white;
        min-height: 100vh;
        padding-bottom: 50px;
    }

    .section-title {
        text-align: center;
        font-family: 'Impact', sans-serif;
        font-size: 3rem;
        text-transform: uppercase;
        padding: 30px 0;
        letter-spacing: 2px;
    }

    .filter-bar {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        max-width: 900px;
        margin: 0 auto 20px auto;
        padding: 0 15px;
    }

    .city-select {
        background: transparent;
        color: #ffeb3b;
        border: 1px solid #ffeb3b;
        padding: 5px 15px;
        border-radius: 5px;
        font-weight: bold;
        cursor: pointer;
    }

        .city-select option {
            background-color: #3b3b98;
            color: white;
        }

    /* Date Tabs */
    .date-tabs {
        display: flex;
        justify-content: center;
        gap: 15px;
        margin-bottom: 40px;
        flex-wrap: wrap;
    }

    .date-item {
        border: 1px solid #ffeb3b;
        color: #ffeb3b;
        padding: 15px 25px;
        border-radius: 5px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s;
        width: 120px;
    }

        .date-item:hover, .date-item.active {
            background-color: #ffeb3b;
            color: #3b3b98;
            font-weight: bold;
            box-shadow: 0 0 15px #ffeb3b;
        }

    .day-number {
        font-size: 1.8rem;
        display: block;
        line-height: 1;
    }

    .day-name {
        font-size: 0.9rem;
        text-transform: uppercase;
    }

    /* Cinema List */
    .cinema-list-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 15px;
    }

    .cinema-item {
        background-color: #4b4bb5;
        margin-bottom: 20px;
        border-radius: 8px;
        overflow: hidden;
    }

    .cinema-header {
        padding: 15px 20px;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .cinema-name {
        color: #ffeb3b;
        font-size: 1.3rem;
        font-weight: bold;
        margin-bottom: 5px;
    }

    .cinema-address {
        font-size: 0.9rem;
        color: #ddd;
    }

    .time-slots {
        padding: 20px;
        border-top: 1px solid rgba(255,255,255,0.1);
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
    }

    .btn-time {
        border: 1px solid white;
        color: white;
        padding: 8px 20px;
        border-radius: 5px;
        text-decoration: none;
        transition: 0.2s;
        display: inline-block;
    }

        .btn-time:hover {
            background-color: white;
            color: #3b3b98;
            text-decoration: none;
        }

    .format-tag {
        font-size: 0.7rem;
        background: #ff5722;
        padding: 2px 5px;
        border-radius: 3px;
        margin-right: 5px;
    }
</style>

<div class="booking-container">
    <div class="container">
        <h2 class="section-title">@Model.TenPhim</h2>

        <div class="date-tabs">
            @foreach (var date in Model.CacNgayChieu)
            {
                var dateKey = date.ToString("ddMMyyyy");
                var activeClass = (dateKey == firstDateKey) ? "active" : "";
                var dayName = System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetDayName(date.DayOfWeek);

                <div class="date-item @activeClass" onclick="showScheduleByDate('@dateKey', this)">
                    <span class="day-number">@date.Day</span>/<span>@date.Month</span>
                    <span class="day-name">@dayName</span>
                </div>
            }
        </div>

        <div class="cinema-list-container">

            <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-2" style="border-color: rgba(255,255,255,0.1) !important;">

                <h3 class="text-uppercase m-0" style="font-weight: bold; color: #ffeb3b; border-bottom: 3px solid #ffeb3b; display: inline-block; padding-bottom: 5px;">
                    Danh Sách Rạp
                </h3>

                <div class="filter-box d-flex align-items-center">
                    <span style="margin-right: 10px; color: #ccc; font-size: 0.9rem; text-transform: uppercase;">
                        <i class="fas fa-map-marker-alt"></i> Khu Vực:
                    </span>
                    <select id="cityFilter" class="city-select" onchange="filterByCity()">
                        <option value="all">Toàn Quốc</option>
                        @foreach (var city in Model.DanhSachThanhPho)
                        {
                            <option value="@city">@city</option>
                        }
                    </select>
                </div>
            </div>

            @foreach (var dateKey in Model.LichChieuTheoNgay.Keys)
            {
                var displayStyle = (dateKey == firstDateKey) ? "block" : "none";

                <div id="schedule-@dateKey" class="schedule-group" style="display: @displayStyle;">
                    @if (Model.LichChieuTheoNgay[dateKey].Count == 0)
                    {
                        <div class="text-center py-5" style="opacity: 0.7;">
                            <i class="fas fa-film fa-3x mb-3"></i>
                            <p>Chưa có suất chiếu nào vào ngày này.</p>
                        </div>
                    }

                    @foreach (var rap in Model.LichChieuTheoNgay[dateKey])
                    {
                        <div class="cinema-item" data-city="@rap.ThanhPho">
                            <div class="cinema-header">
                                <div>
                                    <div class="cinema-name">@rap.TenRap</div>
                                    <div class="cinema-address">
                                        <i class="fas fa-map-pin text-warning mr-1"></i> @rap.DiaChi
                                    </div>
                                </div>
                                <span class="badge badge-light text-dark">@rap.ThanhPho</span>
                            </div>
                            <div class="time-slots">
                                <div style="width: 100%; color: #aaa; margin-bottom: 10px; font-size: 0.85rem;">
                                    <i class="fas fa-layer-group"></i> 2D - Phụ đề
                                </div>
                                @foreach (var suat in rap.DanhSachSuatChieu)
                                {
                                    <a href="javascript:void(0)" class="btn-time" onclick="loadTicketSection(@suat.LichChieuID)">
                                        <span class="format-tag">@suat.DinhDang</span> @suat.GioChieu
                                    </a>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
<div id="ticket-selection-wrapper"></div>
@section scripts {
    <script>
        // Hàm 1: Chuyển Tab Ngày
        function showScheduleByDate(dateKey, element) {
            $('.schedule-group').hide();
            $('#schedule-' + dateKey).fadeIn();

            $('.date-item').removeClass('active');
            $(element).addClass('active');

            // Sau khi chuyển ngày, phải lọc lại theo thành phố đang chọn
            filterByCity();
        }

        // Hàm 2: Lọc theo Thành Phố
        function filterByCity() {
            var selectedCity = $('#cityFilter').val();

            // Tìm nhóm ngày đang hiển thị (đang active)
            var visibleGroup = $('.schedule-group:visible');

            // Duyệt qua từng rạp trong nhóm ngày đó
            visibleGroup.find('.cinema-item').each(function () {
                var cinemaCity = $(this).data('city'); // Lấy thành phố của rạp

                if (selectedCity === 'all' || selectedCity === cinemaCity) {
                    $(this).show();
                } else {
                    $(this).hide();
                }
            });
        }
        function loadTicketSection(lichChieuId) {
            // Hiển thị loading hoặc mờ màn hình nếu cần

            $.ajax({
                url: '@Url.Action("GetTicketSelection", "Booking")',
                data: { lichChieuId: lichChieuId },
                success: function (response) {
                    $('#ticket-selection-wrapper').html(response);

                    // Cuộn màn hình xuống phần chọn vé mượt mà
                    $('html, body').animate({
                        scrollTop: $("#ticketSection").offset().top
                    }, 800);
                },
                error: function () {
                    alert("Lỗi tải thông tin vé!");
                }
            });
        }
    </script>
}