@model Web_Phim.Models.SeatMapViewModel

<style>
    /* CSS giữ nguyên như cũ */
    .seat-map-container {
        background-color: #121220;
        padding: 40px 20px 100px 20px;
        color: white;
        text-align: center;
        animation: slideUp 0.5s ease-out;
        border-top: 1px solid #444;
    }

    .screen-container {
        margin-bottom: 50px;
    }

    .screen-curve {
        height: 60px;
        width: 80%;
        margin: 0 auto;
        border-top: 4px solid white;
        border-radius: 50% 50% 0 0 / 20px 20px 0 0;
        box-shadow: 0 -15px 20px rgba(255, 255, 255, 0.2);
    }

    .screen-text {
        margin-top: 10px;
        font-size: 0.9rem;
        color: #ccc;
    }

    .seat-row {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-bottom: 10px;
    }

    .row-label {
        width: 30px;
        font-weight: bold;
        color: #ccc;
    }

    .seat {
        width: 35px;
        height: 30px;
        margin: 3px;
        border: 1px solid #ccc;
        border-radius: 3px;
        font-size: 0.7rem;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        background-color: white;
        color: black;
        font-weight: bold;
        transition: all 0.2s;
    }

        .seat.couple {
            width: 76px;
        }

        .seat.booked {
            background-color: #555;
            border-color: #555;
            color: #888;
            cursor: not-allowed;
            pointer-events: none;
        }
        /* Chặn click bằng CSS */
        .seat.selected {
            background-color: #ffeb3b;
            border-color: #ffeb3b;
            color: black;
            box-shadow: 0 0 10px #ffeb3b;
        }

    .legend-container {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin-top: 40px;
        flex-wrap: wrap;
    }

    .legend-item {
        display: flex;
        align-items: center;
        font-size: 0.9rem;
        color: #ccc;
    }

    .legend-box {
        width: 20px;
        height: 20px;
        margin-right: 8px;
        border-radius: 3px;
        border: 1px solid #ccc;
    }
</style>

@* --- QUAN TRỌNG: Truyền giới hạn vé vào data-attribute của thẻ bao ngoài --- *@
<div class="seat-map-container" id="seatMapSection"
     data-max-norm="@Model.SoLuongGheDon"
     data-max-couple="@Model.SoLuongGheDoi">

    <h3 class="text-uppercase mb-4">
        Chọn Ghế (@Model.SoLuongGheDon Đơn, @Model.SoLuongGheDoi Đôi)
    </h3>

    <div class="screen-container">
        <div class="screen-curve"></div>
        <div class="screen-text">Màn hình</div>
    </div>

    <div class="seats-grid">
        @foreach (var group in Model.DanhSachGhe.GroupBy(g => g.HangGhe))
        {
            <div class="seat-row">
                <div class="row-label">@group.Key</div>
                @foreach (var seat in group)
                {
                    var classGhe = "seat";
                    if (seat.LoaiGhe == "Doi") { classGhe += " couple"; }
                    if (seat.TrangThai == 1 || seat.TrangThai == 2) { classGhe += " booked"; }

                    @* Không gán onclick cứng, dùng Event Delegation *@
                    <div class="@classGhe"
                         data-id="@seat.GheID"
                         data-code="@seat.MaGhe"
                         data-price="@seat.GiaVe"
                         data-type="@seat.LoaiGhe">
                        @seat.MaGhe
                    </div>
                }
                <div class="row-label">@group.Key</div>
            </div>
        }
    </div>

    @* Phần chú thích giữ nguyên *@
    <div class="legend-container">
        <div class="legend-item"><div class="legend-box" style="background:white;"></div>Ghế Thường</div>
        <div class="legend-item"><div class="legend-box" style="background:white; width:40px;"></div>Ghế Đôi</div>
        <div class="legend-item"><div class="legend-box" style="background:#ffeb3b; border-color:#ffeb3b;"></div>Ghế Đang Chọn</div>
        <div class="legend-item"><div class="legend-box" style="background:#555; border-color:#555;"></div>Ghế Đã Đặt</div>
    </div>
</div>