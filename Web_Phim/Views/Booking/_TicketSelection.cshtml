@model Web_Phim.Models.BookingSummaryViewModel

<style>
    .ticket-selection-container {
        background-color: #1a1a2e;
        padding: 30px 0 100px 0;
        color: white;
        border-top: 1px solid #444;
        animation: slideDown 0.5s ease-out;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .ticket-box {
        border: 1px solid #444;
        border-radius: 5px;
        padding: 15px;
        margin-bottom: 20px;
        background: rgba(255,255,255,0.05);
    }

    .ticket-name {
        font-weight: bold;
        font-size: 1.1rem;
        text-transform: uppercase;
    }

    .ticket-price {
        color: #ffeb3b;
        font-weight: bold;
        margin: 5px 0 15px 0;
    }

    .qty-btn {
        background: #e0e0e0;
        color: #333;
        border: none;
        width: 30px;
        height: 30px;
        font-weight: bold;
        cursor: pointer;
    }

    .qty-input {
        width: 40px;
        text-align: center;
        border: none;
        background: transparent;
        color: white;
        font-size: 1.2rem;
    }

    /* Footer cố định */
    .booking-footer {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        background-color: #0f0f1a;
        border-top: 1px solid #ffeb3b;
        padding: 10px 0;
        z-index: 9999;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 -5px 20px rgba(0,0,0,0.8);
        color: white;
    }

    .movie-title {
        font-weight: 900;
        font-size: 1.1rem;
        text-transform: uppercase;
        margin: 0;
        font-family: 'Arial', sans-serif;
    }

    .cinema-info {
        margin: 0;
        font-size: 0.9rem;
        color: #ccc;
        margin-top: 3px;
    }

    #ticketSummaryText {
        color: white;
        font-weight: bold;
    }
</style>

<div class="ticket-selection-container" id="ticketSection">
    <div class="container">
        <h3 class="text-center text-uppercase mb-5" style="font-weight: 800; letter-spacing: 2px;">Chọn Loại Vé</h3>
        <div class="row">
            @foreach (var item in Model.DanhSachLoaiVe)
            {
                <div class="col-md-4">
                    <div class="ticket-box">
                        <div class="ticket-name ticket-name-text">@item.TenLoaiVe</div>
                        <div class="ticket-price" data-price="@((int)item.GiaBan)">
                            @item.GiaBan.ToString("#,##0") VNĐ
                        </div>
                        <div class="d-flex align-items-center">
                            <button class="qty-btn rounded-left" onclick="updateQty(this, -1)">-</button>
                            <input type="text" class="qty-input" value="0" readonly />
                            <button class="qty-btn rounded-right" onclick="updateQty(this, 1)">+</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
    <div id="seat-map-wrapper"></div>
</div>

<div class="booking-footer">
    <div class="container d-flex justify-content-between align-items-center">
        <div class="text-left">
            <h5 class="movie-title">@Model.TenPhim <span class="text-white">(@Model.PhanLoai)</span></h5>
            <p class="cinema-info">
                @Model.TenRapHienThi
                <span id="ticketSummaryText"></span>
            </p>
        </div>

        <div class="d-flex align-items-center">
            <div class="countdown-box mr-4 text-center bg-warning text-dark p-1 rounded font-weight-bold" style="line-height:1.2">
                <span style="font-size: 0.6rem; display:block">Thời gian giữ vé</span>
                <span id="countdown" style="font-size: 1.2rem;">05:00</span>
            </div>
            <div class="text-right mr-4">
                <span style="color: #ccc; font-size: 0.8rem;">Tạm tính</span><br />
                <span class="total-price font-weight-bold" style="font-size: 1.3rem;" id="totalPrice">0 VNĐ</span>
            </div>
            <button id="btnAction" class="btn btn-warning btn-lg font-weight-bold" onclick="handleBookingAction()">
                TIẾP TỤC
            </button>
        </div>
    </div>
</div>

<script>
    // ==========================================
    // 1. CONFIG & STATE MANAGEMENT
    // ==========================================
    const CONFIG = {
        isUserLoggedIn: @(Session["UserID"] != null ? "true" : "false"),
        lichChieuId: @Model.LichChieuID,
        maxTicketsPerTrans: 8
    };

    // State object để quản lý trạng thái tập trung
    let appState = {
        selectedSeats: [], // Mảng chứa object ghế {id, code, price}
        currentNorm: 0,    // Số ghế thường/vip đang chọn
        currentCouple: 0,  // Số ghế đôi đang chọn
        timer: null        // Biến interval đếm ngược
    };

    let seatMapTimeout; // Debounce cho AJAX load map

    // ==========================================
    // 2. LOGIC XỬ LÝ SỐ LƯỢNG VÉ (STEP 1)
    // ==========================================

    function updateQty(btn, change) {
        var input = $(btn).siblings('.qty-input');
        var currentVal = parseInt(input.val());
        var newVal = currentVal + change;

        // Validate số lượng
        if (newVal < 0) newVal = 0;
        if (newVal > CONFIG.maxTicketsPerTrans) {
            alert(`Tối đa ${CONFIG.maxTicketsPerTrans} vé!`);
            newVal = CONFIG.maxTicketsPerTrans;
        }
        input.val(newVal);

        // Cập nhật tổng tiền tạm tính
        calculateTotalPriceAndSummary();

        // Lấy tổng số lượng vé các loại
        var counts = getCurrentTicketCounts();
        var totalTickets = counts.norm + counts.couple;

        // Reset UI nút bấm
        resetActionButton();

        // Xử lý load lại sơ đồ ghế
        handleMapReload(totalTickets, counts);
    }

    function getCurrentTicketCounts() {
        var qtyNorm = 0;
        var qtyCouple = 0;
        $('.ticket-box').each(function () {
            var qty = parseInt($(this).find('.qty-input').val());
            var name = $(this).find('.ticket-name-text').text().trim().toLowerCase();

            // Logic phân loại vé Đôi vs vé Đơn (Thường/VIP)
            if (name.includes("đôi") || name.includes("couple") || name.includes("doi")) {
                qtyCouple += qty;
            } else {
                qtyNorm += qty;
            }
        });
        return { norm: qtyNorm, couple: qtyCouple };
    }

    function handleMapReload(totalTickets, counts) {
        // Reset đếm ngược nếu đổi số lượng
        if (appState.timer) {
            clearInterval(appState.timer);
            $('#countdown').text("05:00");
        }

        clearTimeout(seatMapTimeout);

        if (totalTickets > 0) {
            // Hiển thị trạng thái loading nhẹ
            $('#seat-map-wrapper').css('opacity', '0.5');

            seatMapTimeout = setTimeout(function () {
                loadSeatMap(counts.norm, counts.couple);
            }, 300);
        } else {
            // Nếu về 0 vé thì xóa map
            $('#seat-map-wrapper').empty().css('opacity', '1');
            resetSelectionState(); // Xóa ghế đã chọn
            updateFooterInfo();
        }
    }

    function loadSeatMap(qtyNorm, qtyCouple) {
        $.ajax({
            url: '/Booking/GetSeatMap',
            data: { lichChieuId: CONFIG.lichChieuId, qtyNorm: qtyNorm, qtyCouple: qtyCouple },
            success: function (response) {
                $('#seat-map-wrapper').html(response).css('opacity', '1');

                // QUAN TRỌNG: Khi map reload, HTML thay đổi -> Reset ghế đã chọn cũ
                resetSelectionState();
                updateFooterInfo();

                // Cuộn xuống map
                $('html, body').animate({ scrollTop: $("#seatMapSection").offset().top }, 500);
            },
            error: function () {
                alert("Lỗi tải sơ đồ ghế!");
                $('#seat-map-wrapper').css('opacity', '1');
            }
        });
    }

    // ==========================================
    // 3. LOGIC CHỌN GHẾ (CORE FIX)
    // ==========================================

    // Sử dụng Event Delegation: Gắn sự kiện vào document
    // Nó sẽ bắt click của bất kỳ .seat nào, kể cả những .seat mới sinh ra do AJAX
    $(document).on('click', '.seat', function() {
        var $el = $(this);

        // Bỏ qua ghế đã bán
        if ($el.hasClass('booked')) return;

        // --- KHẮC PHỤC LỖI SCOPE Ở ĐÂY ---
        // Đọc giới hạn TRỰC TIẾP từ HTML vừa được load về
        // Không dùng biến toàn cục cũ, mà lấy từ DOM hiện tại
        var maxNorm = parseInt($('#seatMapSection').attr('data-max-norm')) || 0;
        var maxCouple = parseInt($('#seatMapSection').attr('data-max-couple')) || 0;

        var seatType = $el.data('type');
        var isCoupleSeat = (seatType === 'Doi');

        if ($el.hasClass('selected')) {
            // --- HỦY CHỌN GHẾ ---
            $el.removeClass('selected');

            // Giảm biến đếm
            if (isCoupleSeat) appState.currentCouple--;
            else appState.currentNorm--;

            // Xóa khỏi mảng
            var id = $el.data('id');
            appState.selectedSeats = appState.selectedSeats.filter(s => s.id !== id);
        }
        else {
            // --- CHỌN GHẾ MỚI ---
            if (isCoupleSeat) {
                if (appState.currentCouple >= maxCouple) {
                    alert(`Bạn chỉ mua ${maxCouple} vé Đôi. Vui lòng kiểm tra lại!`);
                    return;
                }
                appState.currentCouple++;
            } else {
                if (appState.currentNorm >= maxNorm) {
                    alert(`Bạn chỉ mua ${maxNorm} vé Đơn (Thường/VIP). Vui lòng kiểm tra lại!`);
                    return;
                }
                appState.currentNorm++;
            }

            $el.addClass('selected');
            appState.selectedSeats.push({
                id: $el.data('id'),
                code: $el.data('code'),
                price: $el.data('price')
            });
        }

        // Cập nhật Footer sau khi click
        updateFooterInfo();
    });

    // ==========================================
    // 4. LOGIC UI & STATE UPDATES
    // ==========================================

    function calculateTotalPriceAndSummary() {
        var total = 0;
        var summaryItems = [];
        $('.ticket-box').each(function () {
            var price = parseFloat($(this).find('.ticket-price').attr('data-price')) || 0;
            var qty = parseInt($(this).find('.qty-input').val());
            var name = $(this).find('.ticket-name-text').text().trim();
            if (qty > 0) {
                total += price * qty;
                summaryItems.push(`<b>${qty}</b> ${name}`);
            }
        });

        $('#totalPrice').text(total.toLocaleString('vi-VN') + ' VNĐ');

        if (summaryItems.length > 0) {
            // Giữ lại span #seatInfoFooter để điền ghế vào sau
            $('#ticketSummaryText').html(' | ' + summaryItems.join(', ') + ' <span id="seatInfoFooter"></span>');
            updateFooterInfo(); // Re-render ghế nếu có
        } else {
            $('#ticketSummaryText').text('');
        }
    }

    function updateFooterInfo() {
        // Lấy danh sách mã ghế
        var seatCodes = appState.selectedSeats.map(s => s.code).join(', ');

        // Tìm span hiển thị ghế (vì calculateTotalPriceAndSummary có thể vẽ lại HTML cha)
        var seatSpan = $('#seatInfoFooter');
        if (seatSpan.length === 0 && appState.selectedSeats.length > 0) {
             $('#ticketSummaryText').append(' <span id="seatInfoFooter"></span>');
             seatSpan = $('#seatInfoFooter');
        }

        if (seatSpan.length > 0) {
             seatSpan.html(seatCodes ? ` | <span class="text-warning">Ghế: ${seatCodes}</span>` : '');
        }

        // Logic đổi nút bấm
        var counts = getCurrentTicketCounts();
        var totalTicketsNeeded = counts.norm + counts.couple;
        var currentSelected = appState.selectedSeats.length;

        var btn = $('#btnAction');
        // Chỉ cho phép đặt khi số ghế chọn bằng tổng số vé
        if (currentSelected === totalTicketsNeeded && totalTicketsNeeded > 0) {
            btn.text("ĐẶT VÉ")
               .removeClass('btn-warning').addClass('btn-danger')
               .prop('disabled', false);
        } else {
            btn.text("TIẾP TỤC")
               .removeClass('btn-danger btn-success').addClass('btn-warning');
               // Có thể disable nút nếu muốn chặn click khi chưa chọn đủ ghế
        }
    }

    function resetSelectionState() {
        appState.selectedSeats = [];
        appState.currentNorm = 0;
        appState.currentCouple = 0;
    }

    function resetActionButton() {
        $('#btnAction').text("TIẾP TỤC")
            .removeClass('btn-danger btn-success').addClass('btn-warning')
            .prop('disabled', false)
            .attr('onclick', 'handleBookingAction()');
    }

    // ==========================================
    // 5. BOOKING ACTION & TIMER
    // ==========================================

    function handleBookingAction() {
        var counts = getCurrentTicketCounts();
        var totalTickets = counts.norm + counts.couple;

        if (totalTickets === 0) { alert("Vui lòng chọn ít nhất 1 vé!"); return; }

        if (appState.selectedSeats.length < totalTickets) {
            alert(`Bạn chưa chọn đủ ghế! (${appState.selectedSeats.length}/${totalTickets})`);
            $('html, body').animate({ scrollTop: $("#seatMapSection").offset().top }, 500);
            return;
        }

        if (!CONFIG.isUserLoggedIn) {
            if (confirm("Bạn cần đăng nhập để đặt vé. Đi đến trang đăng nhập?")) {
                window.location.href = "/Account/Login";
            }
            return;
        }

        var seatIds = appState.selectedSeats.map(s => s.id).join(',');
        var btn = $('#btnAction');
        var originalText = btn.text();

        btn.text("Đang xử lý...").prop('disabled', true);

        $.ajax({
            url: '/Booking/ConfirmSeats',
            type: 'POST',
            data: { lichChieuId: CONFIG.lichChieuId, seatIds: seatIds },
            success: function (res) {
                if (res.success) {
                    startCountdown();
                    alert("Giữ ghế thành công! Bạn có 5 phút để thanh toán.");
                    btn.text("THANH TOÁN NGAY")
                       .removeClass('btn-danger').addClass('btn-success')
                       .prop('disabled', false)
                       .attr('onclick', "window.location.href='/Payment/Index?lichChieuId=" + CONFIG.lichChieuId + "&seatIds=" + seatIds + "'");
                } else {
                    alert(res.message);
                    btn.text(originalText).prop('disabled', false);
                    // Load lại map để cập nhật ghế vừa bị người khác mua
                    loadSeatMap(counts.norm, counts.couple);
                }
            },
            error: function () {
                alert("Lỗi kết nối Server!");
                btn.text(originalText).prop('disabled', false);
            }
        });
    }

    function startCountdown() {
        var timeLeft = 5 * 60;
        if (appState.timer) clearInterval(appState.timer);
        $('#countdown').text("05:00");

        appState.timer = setInterval(function () {
            var m = Math.floor(timeLeft / 60);
            var s = timeLeft % 60;
            $('#countdown').text((m < 10 ? "0" + m : m) + ":" + (s < 10 ? "0" + s : s));

            if (timeLeft <= 0) {
                clearInterval(appState.timer);
                alert("Hết thời gian giữ vé! Vui lòng đặt lại.");
                location.reload();
            }
            timeLeft -= 1;
        }, 1000);
    }
</script>