@model IEnumerable<Web_Phim.Models.BookingHistoryViewModel>
@{
    ViewBag.Title = "Lịch Sử Đặt Vé";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Layout chung của bạn
}

<style>
    /* CSS đồng bộ màu tối và màu vàng nhấn */
    .history-wrapper {
        background-color: #1a1a2e; /* Nền tối đậm */
        color: white;
        padding: 50px 0;
        min-height: 80vh;
    }

    .card-history {
        background: rgba(255,255,255,0.05); /* Nền kính mờ */
        border: 1px solid #444;
        border-left: 5px solid #ffc107; /* Màu Vàng/Cam nhấn */
        border-radius: 8px;
        margin-bottom: 20px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
        transition: 0.3s;
    }

        .card-history:hover {
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.4);
            transform: translateY(-2px);
        }

    .history-detail-label {
        color: #aaaaaa;
    }

    .status-badge {
        font-weight: bold;
        padding: 5px 10px;
        border-radius: 5px;
        font-size: 0.85rem;
    }

    /* Đơn hàng Thành Công */
    .status-success {
        background-color: #38c172; /* Xanh lá */
        color: #1a1a2e;
    }

    /* Đơn hàng Chưa Thanh Toán/Đang chờ */
    .status-pending {
        background-color: #ffc107; /* Vàng/Cam */
        color: #1a1a2e;
    }

    .btn-outline-info {
        color: #ffc107;
        border-color: #ffc107;
    }

        .btn-outline-info:hover {
            background-color: #ffc107;
            color: #1a1a2e;
        }
    .status-order-id {
        background-color: #333333; /* Xám đậm */
        color: #f8f8f8; /* Chữ sáng */
        /* 💡 THÊM HOẶC SỬA ĐỔI ĐOẠN NÀY ĐỂ CÓ BORDER */
        border: 2px solid #ffc107; /* Viền 2px màu Vàng/Cam nổi bật */
        /* Nếu muốn viền mỏng hơn, dùng border: 1px solid #ffc107; */
    }

</style>

<div class="history-wrapper">
    <div class="container">
        <h2 class="text-center mb-5 font-weight-bold text-warning"> Lịch Sử Đặt Vé </h2>

        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="card card-history p-3">
                    <div class="row align-items-center">
                        <div class="col-md-4">
                            <div class="history-item-container text-md-l">

                                <h5 class="font-weight-bold mb-2  text-warning">@item.TenPhim</h5>

                                <span class="status-badge status-order-id">
                                    Mã Đơn: @item.MaDatVe
                                </span>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <p class="m-0 font-weight-bold">@item.TenRap </p>
                            <p class="m-0 text-warning font-weight-bold">
                                Số lượng vé: @item.SoLuongVe
                            </p>
                            <p class="m-0 text-warning font-weight-bold">
                                Số ghế: @item.DanhSachMaGhe
                            </p>
                        </div>

                        <div class="col-md-4 text-md-center">
                            <p class="m-0 text-warning font-weight-bold" style="font-size: 1.2rem;">
                                @item.TongTienDonHang.ToString("#,##0") VNĐ
                            </p>
                            <p class="m-0 history-detail-label">
                                <small>@item.ThoiGianDat.ToString("HH:mm dd/MM/yyyy")</small>
                            </p>
                        </div>


                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-dark text-center" style="border-left: 5px solid #ffc107;">
                <p class="m-0 text-warning">@ViewBag.Message</p>
                <p class="m-0 mt-2">Bạn chưa có đơn đặt vé nào. Hãy đặt vé ngay!</p>
                <a href="@Url.Action("TrangChu", "Home")" class="btn btn-warning mt-3 font-weight-bold">
                    <i class="fas fa-ticket-alt"></i> ĐẶT VÉ NGAY
                </a>
            </div>
        }
    </div>
</div>