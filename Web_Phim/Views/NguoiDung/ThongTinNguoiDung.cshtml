@model Web_Phim.Models.PersonalInfoViewModel
@{
    ViewBag.Title = "Thông Tin Cá Nhân";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


@section Styles {
    <style>
        /* --- KHUNG CHỨA --- */
        .profile-container {
            background-color: #1A1A2E;
            color: #F8F8F8;
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.6);
            max-width: 900px;
            margin: 40px auto;
        }

        /* --- NHÃN (LABEL) --- */
        .control-label {
            font-weight: normal;
            color: #aaa; /* Màu nhãn hơi chìm xuống để làm nổi dữ liệu lên */
            margin-bottom: 5px;
            font-size: 0.9rem;
            display: block;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* --- Ô INPUT BÌNH THƯỜNG --- */
        .custom-input {
            background-color: #2a2a44;
            border: 1px solid #444;
            color: #fff;
            border-radius: 5px;
            height: 45px;
            padding-left: 15px;
        }

            /* --- QUAN TRỌNG: STYLE CHO Ô HIỂN THỊ (READ-ONLY) --- */
            /* Chỉnh lại đoạn này để nó NỔI LÊN */
            .custom-input:read-only, .readonly-field {
                background-color: #232338; /* Màu nền hơi khác một chút cho đẹp */
                color: #ffc107; /* MÀU VÀNG (hoặc #fff nếu thích trắng) CHO NỔI BẬT */
                font-weight: bold; /* Chữ đậm */
                font-size: 1.1rem; /* Chữ to hơn chút */
                border: 1px solid #444; /* Viền bình thường, không đứt đoạn */
                cursor: default; /* Con trỏ chuột bình thường */
                box-shadow: none; /* Bỏ bóng nếu có */
            }

                /* Khi focus vào ô readonly thì không hiện viền vàng (vì có sửa được đâu) */
                .custom-input:read-only:focus {
                    border-color: #444;
                    box-shadow: none;
                }

        /* --- POPUP --- */
        .modal-content {
            background-color: #1A1A2E;
            color: white;
            border: 2px solid #ffc107;
        }

        .modal-header, .modal-footer {
            border-color: #444;
        }

        .close {
            color: white;
            opacity: 1;
        }
    </style>
}

<div class="profile-container">

    <h2 class="text-center mb-5 font-weight-bold text-white" style="letter-spacing: 2px; text-transform:uppercase;">
        HỒ SƠ CỦA TÔI
    </h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 mb-4">
            <i class="fas fa-check-circle mr-2"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 mb-4">
            <i class="fas fa-exclamation-triangle mr-2"></i> @TempData["Error"]
        </div>
    }

    <div class="row">
        <div class="col-md-6">
            <h5 class="mb-4 text-white pb-2" style="border-bottom: 2px solid #444;">
                <i class="fas fa-id-card mr-2"></i>Thông Tin Cơ Bản
            </h5>

            <div class="form-group mb-4">
                <label class="control-label">Tên tài khoản</label>
                @Html.TextBoxFor(m => m.UserName, new { @class = "form-control custom-input readonly-field", @readonly = "readonly" })
            </div>

            <div class="form-group mb-4">
                <label class="control-label">Họ và tên</label>
                @Html.TextBoxFor(m => m.TenDayDu, new { @class = "form-control custom-input readonly-field", @readonly = "readonly" })
            </div>
        </div>

        <div class="col-md-6">
            <h5 class="mb-4 text-white pb-2" style="border-bottom: 2px solid #444;">
                <i class="fas fa-shield-alt mr-2"></i>Bảo Mật & Liên Hệ
            </h5>

            <div class="form-group mb-4">
                <label class="control-label">Email đăng ký</label>
                @Html.TextBoxFor(m => m.Email, new { @class = "form-control custom-input readonly-field", @readonly = "readonly" })
            </div>

            <div class="form-group mb-4">
                <label class="control-label">Số điện thoại</label>
                @Html.TextBoxFor(m => m.SoDienThoai, new { @class = "form-control custom-input readonly-field", @readonly = "readonly" })
            </div>

            <div class="form-group mb-4">
                <label class="control-label">Mật khẩu</label>
                <div class="input-group">
                    <input type="password" class="form-control custom-input readonly-field" value="********" readonly style="letter-spacing: 3px;" />
                    <div class="input-group-append">
                        <button type="button" class="btn btn-warning font-weight-bold" data-toggle="modal" data-target="#modalDoiMatKhau">
                            <i class="fas fa-pen mr-1"></i> Đổi
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    

</div>

<div class="modal fade" id="modalDoiMatKhau" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-warning font-weight-bold">Đổi Mật Khẩu</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            @using (Html.BeginForm("DoiMatKhau", "NguoiDung", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="UserID" value="@Model.UserID" />

                <div class="modal-body">
                    <div class="form-group">
                        <label class="text-muted">Mật khẩu cũ</label>
                        <input type="password" name="MatKhauCu" class="form-control custom-input" required />
                    </div>
                    <div class="form-group">
                        <label class="text-muted">Mật khẩu mới (Min 8 ký tự)</label>
                        <input type="password" name="MatKhauMoi" class="form-control custom-input" required />
                    </div>
                    <div class="form-group">
                        <label class="text-muted">Nhập lại mật khẩu mới</label>
                        <input type="password" name="XacNhanMatKhau" class="form-control custom-input" required />
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-warning font-weight-bold">Xác Nhận</button>
                </div>
            }
        </div>
    </div>
</div>