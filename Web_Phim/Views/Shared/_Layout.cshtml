
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title - MOVANA</title>

    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="@Url.Content("~/Assets/CSS/Layout.css?v=1.1")" />
    @RenderSection("Styles", required: false)
</head>

<body>
    <!-- HEADER -->
    <div class="header-container">
        <div class="navbar-top">
            <div class="content-wrapper">
                <!-- trái -->
                <a class="navbar-brand" href="@Url.Action("TrangChu", "Home")">
                    <img src="~/Assets/Images/Logo.png" alt="MOVANA Logo" />MOVANA
                </a>

                <!-- phải -->
                <div class="d-flex align-items-center" style="gap: 25px;">
                    <div class="search-box">
                        <i class="fas fa-search"></i>
                        <input type="text" placeholder="Tìm phim, rạp..." />
                    </div>
                    <div class="nav-right">
                        @if (Session["UserName"] != null)
                        {
                            <div class="dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-toggle="dropdown">
                                    <i class="fas fa-user-check"></i> Xin chào, @Session["HoTen"]
                                </a>
                                <div class="dropdown-menu dropdown-menu-right">
                                    @Html.ActionLink("Thông tin cá nhân", "ThongTinNguoiDung", "NguoiDung", null, new { @class = "dropdown-item" })
                                    @Html.ActionLink("Lịch sử đặt vé", "Index", "History", null, new { @class = "dropdown-item" })

                                    @if (Session["Role"] != null && Session["Role"].ToString() == "Admin")
                                    {
                                        @Html.ActionLink("Trang Quản Trị", "TrangQuanLy", "Admin_QuanLy", null, new { @class = "dropdown-item" })
                                    }
                                    <div class="dropdown-divider"></div>
                                    @Html.ActionLink("Đăng xuất", "Logout", "Account", null, new { @class = "dropdown-item" })
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-toggle="dropdown">
                                    <i class="fas fa-user-circle"></i> Tài khoản
                                </a>
                                <div class="dropdown-menu dropdown-menu-right">
                                    @Html.ActionLink("Đăng nhập", "Login", "Account", null, new { @class = "dropdown-item" })
                                    @Html.ActionLink("Đăng ký", "Register", "Account", null, new { @class = "dropdown-item" })
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- SUB NAVBAR -->
        <nav class="sub-navbar">
            <div class="content-wrapper d-flex justify-content-between align-items-center">
                <div class="d-flex">
                    <div class="sub-nav-item"><a href="#"><i class="fas fa-map-marker-alt"></i> Chọn rạp</a></div>
                    <div class="sub-nav-item"><a href="@Url.Action("Showtimes", "Booking")"><i class="fas fa-calendar-alt"></i> Lịch chiếu</a></div>
                </div>
                <div class="d-flex">
                    <div class="sub-nav-item dropdown theloai-hover">
                        <a href="#" class="dropdown-toggle text-white" id="dropdownTheLoai">Thể loại</a>
                        @Html.Action("_TheLoaiDropdown", "Home")
                    </div>
                    <div class="sub-nav-item">@Html.ActionLink("Tổ chức sự kiện", "Events", "Home")</div>
                    <div class="sub-nav-item">@Html.ActionLink("Dịch vụ giải trí khác", "Services", "Home")</div>
                    <div class="sub-nav-item">@Html.ActionLink("Giới thiệu", "About", "Home")</div>
                </div>
            </div>
        </nav>
    </div>

    <!-- MAIN -->
    <div class="main-content">
        <div class="content-wrapper">

            <!-- BANNER -->
            <div id="mainBanner" class="carousel slide banner-container" data-ride="carousel" data-interval="4000">
                <div class="carousel-inner">
                    <div class="carousel-item active"><img src="~/Assets/Images/banner1.png" alt="Banner 1"></div>
                    <div class="carousel-item"><img src="~/Assets/Images/banner2.png"></div>
                    <div class="carousel-item"><img src="~/Assets/Images/banner3.png"></div>
                </div>
            </div>


            
            <div class="py-4">@RenderBody()</div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer>
        <div class="content-wrapper">
            &copy; @DateTime.Now.Year - MOVANA Booking System |
            @Html.ActionLink("Giới thiệu", "About", "Home") |
            @Html.ActionLink("Liên hệ", "Contact", "Home") |
            @Html.ActionLink("Chính sách bảo mật", "Privacy", "Home")
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.2.1.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.12.9/umd/popper.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/js/bootstrap.min.js"></script>
    @RenderSection("scripts", required: false)
    <script>
        $(document).ready(function () {
            // 1. Bắt sự kiện click vào nút "Thể loại"
            $('#dropdownTheLoai').on('click', function (e) {
                e.preventDefault(); // Ngăn trình duyệt nhảy lên đầu trang

                // Tìm menu ".theloai-menu" nằm bên trong ".theloai-hover"
                // và bật/tắt nó (toggle)
                $(this).closest('.theloai-hover').find('.theloai-menu').toggle();
            });

            // 2. Tùy chọn: Ẩn menu đi nếu click ra ngoài
            $(document).on('click', function (e) {
                // Nếu click KHÔNG phải là nút "Thể loại"
                // VÀ cũng KHÔNG phải là bên trong cái menu
                if (!$(e.target).closest('.theloai-hover').length) {
                    // Thì ẩn menu đi
                    $('.theloai-menu').hide();
                }
            });
        });
    </script>
</body>
</html>
