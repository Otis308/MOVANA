@* 1. KHAI BÁO ĐÚNG MODEL: Phải là PhimViewModel *@
@model IEnumerable<Web_Phim.Models.PhimViewModel>

@{
    ViewBag.Title = "TrangChu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="@Url.Content("~/Assets/CSS/TrangChu.css?v=1.1")" />
<div class="content-wrapper">
    @if (ViewBag.TenTheLoai != null)
    {
        <h2 class="text-center mt-5" style="font-weight: bold;">
            PHIM THỂ LOẠI: @ViewBag.TenTheLoai
        </h2>
    }
    <div class="phim-container">

        @* 2. SỬA FOREACH: Dùng 'var' để nó tự nhận PhimViewModel *@
        @foreach (var s in Model)
        {
            <div class="phim-card">
                <img src="@Url.Content("~/Assets/Images/" + s.Poster)" alt="@s.TenPhim" />

                <div class="phim-info">
                    <p class="phim-title">
                        @(s.TenPhim.Length > 25 ? s.TenPhim.Substring(0, 25) + "..." : s.TenPhim)
                    </p>
                    @if (s.GiaVeThapNhat > 0)
                    {
                        <p class="phim-price">Từ @s.GiaVeThapNhat.ToString("#,##0") VNĐ</p>
                    }
                    else
                    {
                        <p class="phim-price">Chưa có suất chiếu</p>
                    }
                    <div class="phim-buttons">
                        @Html.ActionLink("Chi Tiết", "ChiTietPhim", "Home", new { id = s.PhimID }, new { @class = "btn btn-info btn-sm" })

                        <a href="@Url.Action("SelectCinema", "Booking", new { id = s.PhimID })" class="btn btn-success btn-sm">
                            <i class="fas fa-ticket-alt"></i> Đặt Vé
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
