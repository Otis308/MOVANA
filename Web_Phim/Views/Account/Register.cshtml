@model Web_Phim.Models.RegisterViewModel
@{
    Layout = null; /* Không dùng Layout chung */
    ViewBag.Title = "Đăng Ký - MOVANA";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.1/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            /* Dùng chung hình nền với trang Login để đồng bộ */
            background: linear-gradient(rgba(0, 0, 0, 0.75), rgba(0, 0, 0, 0.75)), url('https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80');
            background-size: cover;
            background-position: center;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px 0; /* Thêm padding để không bị dính lề khi màn hình nhỏ */
        }

        .register-card {
            width: 100%;
            max-width: 550px; /* Rộng hơn login xíu vì nhiều trường hơn */
            background: rgba(255, 255, 255, 0.95);
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.6);
        }

        .register-header {
            text-align: center;
            margin-bottom: 25px;
        }

            .register-header h3 {
                font-weight: 700;
                color: #28a745; /* Màu xanh lá chủ đạo */
                margin-top: 10px;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

            .register-header i {
                font-size: 45px;
                background: -webkit-linear-gradient(#28a745, #218838);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

        /* Input Styles */
        .form-group label {
            font-weight: 600;
            font-size: 13px;
            color: #6c757d;
            margin-bottom: 5px;
            text-transform: uppercase;
        }

        .form-control {
            height: 45px;
            border-radius: 5px;
            background-color: #f8f9fa;
            border: 1px solid #ced4da;
            font-size: 14px;
        }

            .form-control:focus {
                box-shadow: none;
                border-color: #28a745;
                background-color: #fff;
            }

        .input-group-text {
            background-color: #f8f9fa;
            border: 1px solid #ced4da;
            border-right: none;
            color: #6c757d;
            width: 45px;
            justify-content: center;
        }

        .form-control:focus + .input-group-prepend .input-group-text,
        .input-group:focus-within .input-group-text {
            border-color: #28a745;
            color: #28a745;
        }

        .btn-register {
            height: 50px;
            background: linear-gradient(to right, #28a745, #218838); /* Gradient Xanh lá */
            border: none;
            font-weight: 600;
            font-size: 16px;
            letter-spacing: 1px;
            box-shadow: 0 4px 15px rgba(40, 167, 69, 0.4);
            transition: all 0.3s ease;
            margin-top: 10px;
        }

            .btn-register:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(40, 167, 69, 0.5);
            }

        .footer-link {
            text-align: center;
            margin-top: 25px;
            padding-top: 20px;
            border-top: 1px solid #eee;
            font-size: 14px;
        }

            .footer-link a {
                color: #28a745;
                font-weight: 600;
                text-decoration: none;
            }

                .footer-link a:hover {
                    text-decoration: underline;
                }
    </style>
</head>
<body>

    <div class="register-card">
        <div class="register-header">
            <i class="fas fa-ticket-alt"></i>
            <h3>Đăng Ký</h3>
            <p class="text-muted small">Tham gia cộng đồng MOVANA ngay hôm nay</p>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @* Ẩn cái summary mặc định đi, chỉ hiện lỗi chi tiết bên dưới input *@
            @Html.ValidationSummary(true, "", new { @class = "text-danger text-center mb-3" })

            <div class="form-group">
                @Html.LabelFor(m => m.FullName)
                <div class="input-group">
                    <div class="input-group-prepend">
                        <span class="input-group-text"><i class="fas fa-id-card"></i></span>
                    </div>
                    @Html.TextBoxFor(m => m.FullName, new { @class = "form-control", @placeholder = "Ví dụ: Nguyễn Văn A" })
                </div>
                @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "text-danger small" })
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        @Html.LabelFor(m => m.UserName)
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text"><i class="fas fa-user"></i></span>
                            </div>
                            @Html.TextBoxFor(m => m.UserName, new { @class = "form-control", @placeholder = "username123" })
                        </div>
                        @Html.ValidationMessageFor(m => m.UserName, "", new { @class = "text-danger small" })
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        @Html.LabelFor(m => m.Phone)
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text"><i class="fas fa-phone"></i></span>
                            </div>
                            @Html.TextBoxFor(m => m.Phone, new { @class = "form-control", @placeholder = "090xxxxxxx" })
                        </div>
                        @Html.ValidationMessageFor(m => m.Phone, "", new { @class = "text-danger small" })
                    </div>
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.Email)
                <div class="input-group">
                    <div class="input-group-prepend">
                        <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                    </div>
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", @type = "email", @placeholder = "email@example.com" })
                </div>
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        @Html.LabelFor(m => m.Password)
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text"><i class="fas fa-lock"></i></span>
                            </div>
                            @Html.PasswordFor(m => m.Password, new { @class = "form-control", @placeholder = "******" })
                        </div>
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        @Html.LabelFor(m => m.ConfirmPassword)
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text"><i class="fas fa-check-circle"></i></span>
                            </div>
                            @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", @placeholder = "******" })
                        </div>
                        @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small" })
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-success btn-block btn-register text-uppercase">
                Đăng Ký Ngay
            </button>
        }

        <div class="footer-link">
            <p class="mb-1">Đã có tài khoản ?</p>
            <a href="@Url.Action("Login", "Account")" class="btn btn-outline-secondary btn-sm rounded-pill px-4 mt-2">
                <i class="fas fa-sign-in-alt"></i> Đăng nhập
            </a>
            <p class="mt-3 mb-0"><a href="@Url.Action("TrangChu", "Home")" class="text-muted small"><i class="fas fa-arrow-left"></i> Quay lại trang chủ</a></p>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
</body>
</html>