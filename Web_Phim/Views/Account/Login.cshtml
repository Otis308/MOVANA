@model Web_Phim.Models.LoginViewModel
@{
    Layout = null; /* QUAN TRỌNG: Không dùng Layout chung */
    ViewBag.Title = "Đăng Nhập - MOVANA";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.1/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            /* Hình nền chủ đề phim, tối màu */
            background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)), url('https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80');
            background-size: cover;
            background-position: center;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            background: rgba(255, 255, 255, 0.95); /* Nền trắng hơi trong suốt */
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 15px 25px rgba(0, 0, 0, 0.5);
        }

        .login-header {
            text-align: center;
            margin-bottom: 30px;
        }

            .login-header h3 {
                font-weight: 600;
                color: #333;
                margin-top: 10px;
            }

            .login-header i {
                font-size: 40px;
                color: #007bff; /* Màu chủ đạo */
            }

        .form-control {
            height: 45px;
            border-radius: 5px;
            background-color: #f7f9fc;
            border: 1px solid #e0e0e0;
        }

            .form-control:focus {
                box-shadow: none;
                border-color: #007bff;
                background-color: #fff;
            }

        .input-group-text {
            background-color: #f7f9fc;
            border: 1px solid #e0e0e0;
            border-right: none;
            color: #666;
        }

        /* Fix viền khi input focus */
        .form-control:focus + .input-group-prepend .input-group-text,
        .input-group:focus-within .input-group-text {
            border-color: #007bff;
        }

        .btn-login {
            height: 45px;
            background: linear-gradient(to right, #007bff, #0056b3);
            border: none;
            font-weight: 500;
            letter-spacing: 1px;
            box-shadow: 0 4px 15px rgba(0, 123, 255, 0.3);
            transition: 0.3s;
        }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(0, 123, 255, 0.4);
            }

        .footer-link {
            text-align: center;
            margin-top: 20px;
            font-size: 14px;
            color: #666;
        }

            .footer-link a {
                color: #007bff;
                font-weight: 600;
                text-decoration: none;
            }

                .footer-link a:hover {
                    text-decoration: underline;
                }

        /* Custom Validation Message */
        .field-validation-error {
            font-size: 12px;
            color: #dc3545;
            margin-top: 5px;
            display: block;
        }
    </style>
</head>
<body>

    <div class="login-card">
        <div class="login-header">
            <i class="fas fa-film"></i>
            <h3>MOVANA LOGIN</h3>
            <p class="text-muted">Chào mừng bạn quay trở lại!</p>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty] != null && ViewData.ModelState[string.Empty].Errors.Count > 0)
        {
            <div class="alert alert-danger">
                @Html.ValidationSummary(true, "")
            </div>
        }

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <div class="form-group mb-3">
                <label class="font-weight-bold text-muted small">TÊN ĐĂNG NHẬP</label>
                <div class="input-group">
                    <div class="input-group-prepend">
                        <span class="input-group-text"><i class="fas fa-user"></i></span>
                    </div>
                    @Html.TextBoxFor(m => m.UserName, new { @class = "form-control", @placeholder = "Nhập username của bạn" })
                </div>
                @Html.ValidationMessageFor(m => m.UserName, "", new { @class = "text-danger small" })
            </div>

            <div class="form-group mb-4">
                <label class="font-weight-bold text-muted small">MẬT KHẨU</label>
                <div class="input-group">
                    <div class="input-group-prepend">
                        <span class="input-group-text"><i class="fas fa-lock"></i></span>
                    </div>
                    @Html.PasswordFor(m => m.Password, new { @class = "form-control", @placeholder = "Nhập mật khẩu" })
                </div>
                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
            </div>

            <button type="submit" class="btn btn-primary btn-block btn-login text-uppercase">
                Đăng Nhập
            </button>
        }

        <div class="footer-link">
            <p>Chưa có tài khoản? @Html.ActionLink("Đăng ký ngay", "Register")</p>
            <p><a href="@Url.Action("TrangChu", "Home")" class="text-secondary"><i class="fas fa-arrow-left"></i> Về trang chủ</a></p>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
</body>
</html>