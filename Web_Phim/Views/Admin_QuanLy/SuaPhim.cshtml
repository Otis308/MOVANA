@model Web_Phim.Models.Phim
@{
    ViewBag.Title = "Sửa Phim";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* =========================
       MOVANA THEME ÁP DỤNG TOÀN VIEW
       ========================= */
    :root {
        --bg-dark: #0b0f25;
        --bg-card: rgba(255,255,255,0.05);
        --border-gold: #ffeb00;
        --text-light: #ffffff;
        --text-gold: #ffeb00;
        --radius: 10px;
    }

    body {
        background-color: var(--bg-dark);
    }

    label {
        color: var(--text-gold);
        font-weight: bold;
    }

    .form-control {
        background: #11182f !important;
        border: 1px solid #394058 !important;
        color: white !important;
    }

        .form-control:focus {
            border-color: var(--text-gold) !important;
            box-shadow: 0 0 8px rgba(255, 235, 0, 0.4);
        }

    /* =============================
       BUTTON MOVANA CHUẨN
       ============================= */
    .btn-movana {
        position: relative;
        display: inline-block;
        padding: 14px 35px;
        font-size: 20px;
        font-weight: 700;
        color: black;
        background: #ffeb00;
        border-radius: 10px;
        text-decoration: none !important;
        overflow: hidden;
        cursor: pointer;
        transition: 0.3s;
        border: none;
        z-index: 1;
    }

        .btn-movana::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, #7f00ff, #3a7bd5);
            transform: translateX(-100%);
            transition: transform 0.45s ease-in-out;
            z-index: -1;
            border-radius: 10px;
        }

        .btn-movana:hover::before {
            transform: translateX(0);
        }

        .btn-movana:hover {
            color: #fff !important;
        }
</style>

<div class="container mt-5 text-light" style="max-width:900px;">
    <h2 class="text-center mb-4" style="color: var(--text-gold); font-weight: 800;">
        Sửa Thông Tin Phim
    </h2>

    @using (Html.BeginForm("SuaPhim", "Admin_QuanLy", FormMethod.Post,
        new { enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.PhimID)

        <!-- Tên Phim -->
        <div class="mb-3">
            <label class="form-label">Tên Phim</label>
            @Html.TextBoxFor(m => m.TenPhim, new { @class = "form-control" })
        </div>

        <!-- Mô tả -->
        <div class="mb-3">
            <label class="form-label">Mô tả phim</label>
            @Html.TextAreaFor(m => m.MoTa,
                new { @class = "form-control bg-dark text-light border-secondary", rows = "5" })
        </div>

        <!-- Ngày khởi chiếu -->
        <div class="mb-3">
            <label class="form-label">Ngày khởi chiếu</label>
            @Html.TextBoxFor(
                m => m.NgayKhoiChieu,
                "{0:yyyy-MM-dd}",
                new { @class = "form-control", type = "date" }
            )
        </div>

        <!-- Thời lượng -->
        <div class="mb-3">
            <label class="form-label">Thời lượng (phút)</label>
            @Html.TextBoxFor(m => m.ThoiLuong,
                new { @class = "form-control", type = "number", min = "1" })
        </div>

        <!-- Đạo diễn -->
        <div class="mb-3">
            <label class="form-label">Đạo diễn</label>
            @Html.TextBoxFor(m => m.DaoDien,
                new { @class = "form-control", placeholder = "Nhập tên đạo diễn..." })
        </div>

        <!-- Độ tuổi -->
        <div class="mb-3">
            <label class="form-label">Độ tuổi</label>
            <div class="d-flex gap-4 mt-2 text-light">
                <label><input type="radio" name="PhanLoaiDoTuoi" value="13-" @(Model.PhanLoaiDoTuoi == "13-" ? "checked" : "") /> 13-</label>
                <label><input type="radio" name="PhanLoaiDoTuoi" value="13+" @(Model.PhanLoaiDoTuoi == "13+" ? "checked" : "") /> 13+</label>
                <label><input type="radio" name="PhanLoaiDoTuoi" value="16+" @(Model.PhanLoaiDoTuoi == "16+" ? "checked" : "") /> 16+</label>
                <label><input type="radio" name="PhanLoaiDoTuoi" value="18+" @(Model.PhanLoaiDoTuoi == "18+" ? "checked" : "") /> 18+</label>
            </div>
        </div>

        <!-- Poster hiện tại -->
        <div class="mb-3">
            <label class="form-label">Poster hiện tại</label><br />
            <img src="@Url.Content("~/Assets/Images/" + Model.Poster)" width="120" class="rounded shadow" />
        </div>

        <!-- Poster mới -->
        <div class="mb-4">
            <label class="form-label">Đổi poster mới</label>
            <input type="file" name="PosterFile" class="form-control" />
        </div>

        <!-- Thể loại -->
        <div class="mb-4">
            <label class="form-label">Thể loại</label>
            @Html.DropDownList("MaTheLoai",
                ViewBag.TheLoaiList as SelectList,
                new { @class = "form-control" })
        </div>

        <!-- Nút lưu MOVANA -->
        <button type="submit" class="btn-movana">Lưu thay đổi</button>
    }
</div>
