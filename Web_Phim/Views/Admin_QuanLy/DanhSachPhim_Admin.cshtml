@model IEnumerable<Web_Phim.Models.Phim>

@{
    ViewBag.Title = "Danh sách phim";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="@Url.Content("~/Assets/CSS/TrangChu.css")" />

<style>
    /* ============================
       NÚT MOVANA (CHUẨN)
       ============================ */
    .btn-movana {
        position: relative;
        display: inline-block;
        padding: 10px 22px;
        font-size: 16px;
        font-weight: 700;
        color: black;
        background: #ffeb00;
        border-radius: 10px;
        text-decoration: none !important;
        overflow: hidden;
        cursor: pointer;
        transition: 0.3s;
        border: none;
        margin-right: 10px;
        z-index: 1;
    }

        .btn-movana::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, #7f00ff, #3a7bd5);
            transform: translateX(-100%);
            transition: transform 0.45s ease-in-out;
            z-index: -1;
            border-radius: 10px;
        }

        .btn-movana:hover::before {
            transform: translateX(0);
        }

        .btn-movana:hover {
            color: #fff !important;
        }
</style>


<div class="content-wrapper">

    <h2 class="text-center mt-4" style="color: #ffeb00; font-weight: bold;">
        DANH SÁCH PHIM (ADMIN)
    </h2>

    <div class="phim-container">

        @foreach (var s in Model)
        {
            <div class="phim-card">

                <img src="@Url.Content("~/Assets/Images/" + s.Poster)" alt="@s.TenPhim" />

                <div class="phim-info">

                    <!-- TÊN PHIM (không còn ID nữa) -->
                    <p class="phim-title">
                        @(s.TenPhim.Length > 25 ? s.TenPhim.Substring(0, 25) + "..." : s.TenPhim)
                    </p>

                    <div class="phim-buttons">

                        <!-- NÚT SỬA PHIM -->
                        <a href="@Url.Action("SuaPhim", "Admin_QuanLy", new { id = s.PhimID })"
                           class="btn-movana">
                            Sửa phim
                        </a>

                        <!-- NÚT XÓA PHIM -->
                        <a href="@Url.Action("XoaPhim", "Admin_QuanLy", new { id = s.PhimID })"
                           class="btn-movana">
                            Xóa phim
                        </a>

                    </div>

                </div>
            </div>
        }

    </div>

</div>
