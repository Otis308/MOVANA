@{
    ViewBag.Title = "Dashboard Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --bg-dark: #0b0f25;
        --bg-card: rgba(255,255,255,0.05);
        --border-gold: #ffeb00;
        --text-light: #ffffff;
        --text-gold: #ffeb00;
        --text-gray: #aaaaaa;
        --radius: 10px;
    }

    body {
        background: var(--bg-dark);
    }

    .admin-wrapper {
        padding: 50px 0;
        min-height: 80vh;
        color: var(--text-light);
    }

    .admin-card {
        background: var(--bg-card);
        border: 1px solid var(--border-gold);
        border-left: 6px solid var(--border-gold);
        border-radius: var(--radius);
        padding: 25px 20px;
        margin-bottom: 25px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.4);
        transition: .25s ease;
    }

        .admin-card:hover {
            background: rgba(255,255,255,0.08);
            transform: translateY(-3px);
            box-shadow: 0 6px 22px rgba(0,0,0,0.6);
        }

    .admin-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--text-gold);
        margin-bottom: 12px;
    }

    .admin-desc {
        color: var(--text-gray);
        font-size: .95rem;
    }

    /* ===========================
       MOVANA BUTTON STYLE
       =========================== */
    .btn-movana {
        position: relative;
        display: inline-block;
        padding: 12px 28px;
        font-size: 18px;
        font-weight: 700;
        color: black;
        background: #ffeb00;
        border-radius: 10px;
        text-decoration: none !important;
        overflow: hidden;
        cursor: pointer;
        transition: 0.3s;
        border: none;
        z-index: 1;
    }

        .btn-movana::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, #7f00ff, #3a7bd5);
            transform: translateX(-100%);
            transition: transform 0.45s ease-in-out;
            z-index: -1;
            border-radius: 10px;
        }

        .btn-movana:hover::before {
            transform: translateX(0);
        }

        .btn-movana:hover {
            color: #fff !important;
        }
</style>

<div class="admin-wrapper">
    <div class="container">
        <h2 class="text-center mb-5" style="color: var(--text-gold); font-weight: 700;">
            QUẢN TRỊ HỆ THỐNG MOVANA
        </h2>

        <div class="row">

            <!-- QUẢN LÝ PHIM -->
            <div class="col-md-4">
                <div class="admin-card">
                    <div class="admin-title"><i class="fas fa-film"></i> Quản lý phim</div>
                    <p class="admin-desc">Thêm, sửa, xóa và cập nhật thông tin phim đang chiếu.</p>
                    <a href="@Url.Action("TrangQuanLy_Phim", "Admin_QuanLy")" class="btn-movana">Truy cập</a>
                </div>
            </div>

            <!-- QUẢN LÝ VÉ -->
            <div class="col-md-4">
                <div class="admin-card">
                    <div class="admin-title"><i class="fas fa-ticket-alt"></i> Quản lý vé</div>
                    <p class="admin-desc">Xem danh sách vé bán ra, doanh thu và tình trạng vé.</p>
                    <a href="@Url.Action("Index", "VeAdmin")" class="btn-movana">Truy cập</a>
                </div>
            </div>

            <!-- QUẢN LỊCH CHIẾU -->
            <div class="col-md-4">
                <div class="admin-card">
                    <div class="admin-title"><i class="fas fa-calendar-alt"></i> Lịch chiếu</div>
                    <p class="admin-desc">Tạo mới, chỉnh sửa các suất chiếu cho từng bộ phim.</p>
                    <a href="@Url.Action("ThemLichChieu", "Admin_QuanLy")" class="btn-movana">Truy cập</a>
                </div>
            </div>

            <!-- NGƯỜI DÙNG -->
            <div class="col-md-4">
                <div class="admin-card">
                    <div class="admin-title"><i class="fas fa-users"></i> Người dùng</div>
                    <p class="admin-desc">Quản lý tài khoản khách hàng, admin, nhân viên.</p>
                    <a href="@Url.Action("QuanLyNguoiDung", "Admin")" class="btn-movana">Truy cập</a>
                </div>
            </div>

            <!-- RẠP -->
            <div class="col-md-4">
                <div class="admin-card">
                    <div class="admin-title"><i class="fas fa-building"></i> Quản lý rạp</div>
                    <p class="admin-desc">Thêm và chỉnh sửa thông tin các rạp chiếu.</p>
                    <a href="@Url.Action("Index", "RapAdmin")" class="btn-movana">Truy cập</a>
                </div>
            </div>

            <!-- BÁO CÁO -->
            <div class="col-md-4">
                <div class="admin-card">
                    <div class="admin-title"><i class="fas fa-chart-line"></i> Báo cáo doanh thu</div>
                    <p class="admin-desc">Theo dõi doanh thu theo phim, ngày, rạp.</p>
                    <a href="@Url.Action("BaoCao", "Admin")" class="btn-movana">Xem báo cáo</a>
                </div>
            </div>

        </div>
    </div>
</div>
