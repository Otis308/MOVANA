@model Web_Phim.Models.PaymentInfoViewModel
@{
    ViewBag.Title = "Thanh toán";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Giữ nguyên Layout chung của web
}

<style>
    /* CSS riêng cho trang thanh toán */
    .payment-wrapper {
        background-color: #1a1a2e; /* Màu nền tối */
        color: white;
        min-height: 100vh;
        padding: 50px 0;
    }

    .payment-box {
        background: rgba(255,255,255,0.05); /* Nền kính mờ */
        border: 1px solid #444;
        border-radius: 10px;
        padding: 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    }

    /* CSS cho nút chọn phương thức */
    .method-item {
        background: white;
        color: #333;
        padding: 15px;
        margin-bottom: 15px;
        border-radius: 8px;
        cursor: pointer;
        transition: 0.3s;
        display: flex;
        align-items: center;
        border: 2px solid transparent; /* Viền trong suốt mặc định */
    }

        /* Hiệu ứng khi di chuột vào nút */
        .method-item:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        }

        /* Hiệu ứng khi nút ĐƯỢC CHỌN (Javascript sẽ thêm class này) */
        .method-item.active {
            border-color: #ffc107; /* Viền vàng */
            background: #fffbe6; /* Nền vàng nhạt */
        }

    .method-icon {
        width: 50px;
        height: 50px;
        object-fit: contain;
        margin-right: 15px;
    }

    .dashed-line {
        border-bottom: 1px dashed #555;
        margin: 15px 0;
    }
</style>

<div class="payment-wrapper">
    <div class="container">
        <h2 class="text-center mb-5 text-uppercase font-weight-bold" style="letter-spacing: 2px;">Xác nhận thanh toán</h2>

        <div class="row">
            <div class="col-md-5 mb-4">
                <div class="payment-box">
                    <h4 class="text-warning mb-4" style="border-bottom: 2px solid #ffc107; display:inline-block; padding-bottom:5px;">
                        Thông tin vé
                    </h4>

                    <p class="mb-2"><strong>Phim:</strong> <span style="font-size: 1.1em;">@Model.TenPhim</span></p>
                    <p class="mb-2"><strong>Rạp:</strong> @Model.TenRap</p>
                    <p class="mb-2"><strong>Suất chiếu:</strong> @Model.SuatChieu</p>
                    <p class="mb-2"><strong>Số lượng vé:</strong> @Model.SoLuongVe vé</p>

                    <div class="dashed-line"></div>

                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="m-0">TỔNG TIỀN:</h5>
                        <h3 class="text-warning m-0 font-weight-bold">@Model.TongTien.ToString("#,##0") VNĐ</h3>
                    </div>
                </div>
            </div>

            <div class="col-md-7">
                <div class="payment-box">
                    <h4 class="mb-4">Chọn hình thức thanh toán</h4>

                    <div class="method-item" onclick="chooseMethod('MoMo', this)">
                        <img src="https://upload.wikimedia.org/wikipedia/vi/f/fe/MoMo_Logo.png" class="method-icon" alt="MoMo" />
                        <div>
                            <h6 class="m-0 font-weight-bold">Ví điện tử MoMo</h6>
                            <small class="text-muted">Quét mã QR để thanh toán nhanh chóng</small>
                        </div>
                    </div>

                    <div class="method-item" onclick="chooseMethod('MBBank', this)">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/2/25/Logo_MB_new.png" class="method-icon" alt="MBBank" />
                        <div>
                            <h6 class="m-0 font-weight-bold">Ngân hàng MB Bank</h6>
                            <small class="text-muted">Chuyển khoản 24/7 miễn phí</small>
                        </div>
                    </div>

                    <button id="btnConfirm" class="btn btn-warning btn-block btn-lg mt-4 font-weight-bold" disabled onclick="submitPayment()">
                        THANH TOÁN NGAY
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    var selectedMethod = ""; // Biến lưu tên phương thức đang chọn

    // Hàm 1: Xử lý giao diện khi người dùng click chọn ngân hàng
    function chooseMethod(methodName, element) {
        // Xóa class 'active' ở tất cả các nút (để bỏ viền vàng cũ)
        $('.method-item').removeClass('active');

        // Thêm class 'active' vào nút vừa bấm (để hiện viền vàng mới)
        $(element).addClass('active');

        // Lưu tên phương thức vào biến
        selectedMethod = methodName;

        // Mở khóa nút thanh toán
        $('#btnConfirm').prop('disabled', false);
    }

    // Hàm 2: Gửi dữ liệu về Server khi ấn nút "THANH TOÁN NGAY"
    function submitPayment() {
        if (!selectedMethod) {
            alert("Vui lòng chọn phương thức thanh toán!");
            return;
        }

        var btn = $('#btnConfirm');
        // Đổi chữ nút để báo đang chạy
        btn.html('<i class="fa fa-spinner fa-spin"></i> Đang xử lý...').prop('disabled', true);

        // Gọi AJAX về Controller
        $.ajax({
            url: '/Payment/ProcessPayment', // Đường dẫn đến hàm trong C#
            type: 'POST',
            data: {
                // Lấy dữ liệu từ Model truyền sang JavaScript
                lichChieuId: '@Model.LichChieuID',
                seatIds: '@Model.SeatIds',
                paymentMethod: selectedMethod
            },
            success: function (res) {
                if (res.success) {
                    // Nếu thành công -> Chuyển sang trang xem vé
                    window.location.href = '/Payment/Success';
                } else {
                    // Nếu thất bại -> Hiện lỗi
                    alert(res.message);
                    btn.text('THANH TOÁN NGAY').prop('disabled', false);
                }
            },
            error: function () {
                alert("Lỗi kết nối Server! Vui lòng thử lại.");
                btn.text('THANH TOÁN NGAY').prop('disabled', false);
            }
        });
    }
</script>