@model Web_Phim.Models.BillViewModel
@{
    ViewBag.Title = "Đặt vé thành công";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Nền tối bao quanh */
    .success-wrapper {
        background-color: #1a1a2e;
        min-height: 100vh;
        display: flex;  
        justify-content: center;
        align-items: center;
        padding: 40px 15px;
    }

    /* Khung hóa đơn trắng */
    .bill-ticket {
        background: #fff;
        width: 100%;
        max-width: 450px;
        border-radius: 5px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        overflow: hidden;
        position: relative;
        animation: slideUp 0.6s ease-out;
    }

    /* Hiệu ứng trượt lên khi hiện ra */
    @@keyframes slideUp {
        from {
            transform: translateY(50px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    /* Header xanh lá */
    .bill-header {
        background: #28a745;
        color: white;
        padding: 30px 20px;
        text-align: center;
    }

    .check-icon {
        font-size: 60px;
        margin-bottom: 10px;
    }

    /* Phần thân hóa đơn */
    .bill-body {
        padding: 30px;
        color: #333;
    }

    /* Các dòng thông tin */
    .bill-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 15px;
        border-bottom: 1px dashed #ddd; /* Đường kẻ đứt nét */
        padding-bottom: 8px;
    }

        .bill-row:last-child {
            border-bottom: none;
        }

    .bill-label {
        color: #666;
        font-size: 0.95rem;
    }

    .bill-value {
        font-weight: bold;
        color: #000;
        text-align: right;
    }

    /* Răng cưa ở đáy hóa đơn (Trang trí) */
    .bill-ticket::after {
        content: "";
        position: absolute;
        bottom: -10px;
        left: 0;
        width: 100%;
        height: 20px;
        background: radial-gradient(circle, transparent, transparent 50%, #fff 50%, #fff);
        background-size: 20px 20px;
        transform: rotate(180deg);
    }
</style>

<div class="success-wrapper">
    <div class="bill-ticket">
        <div class="bill-header">
            <div class="check-icon">✓</div>
            <h4 class="text-uppercase font-weight-bold m-0">Thanh toán thành công</h4>
            <p class="m-0 mt-2" style="font-size: 0.9rem; opacity: 0.9;">Cảm ơn bạn đã sử dụng dịch vụ</p>
        </div>

        <div class="bill-body">

            <div class="text-center mb-4">
                <span style="color:#888; font-size:0.9rem;">Mã đơn hàng</span>
                <h2 style="color:#333; font-weight:800; letter-spacing:1px;">#@Model.DonDatVeID</h2>
            </div>

            <div class="bill-row">
                <span class="bill-label">Phim</span>
                <span class="bill-value text-uppercase">@Model.TenPhim</span>
            </div>

            <div class="bill-row">
                <span class="bill-label">Rạp</span>
                <span class="bill-value">@Model.TenRap</span>
            </div>

            <div class="bill-row">
                <span class="bill-label">Ghế đã chọn</span>
                <span class="bill-value text-danger" style="font-size: 1.1rem;">@Model.DanhSachGhe</span>
            </div>

            <div class="bill-row">
                <span class="bill-label">Thời gian đặt</span>
                <span class="bill-value">@Model.ThoiGianDat.ToString("HH:mm dd/MM/yyyy")</span>
            </div>

            <div class="bill-row">
                <span class="bill-label">Phương thức</span>
                <span class="bill-value">@Model.PhuongThuc</span>
            </div>

            <div class="mt-4 pt-3" style="border-top: 2px solid #333; display:flex; justify-content:space-between; align-items:center;">
                <span style="font-weight:bold; font-size:1.1rem;">TỔNG CỘNG</span>
                <span style="font-weight:900; font-size:1.5rem; color:#28a745;">@Model.TongTien.ToString("#,##0") đ</span>
            </div>

            <a href="/Home/TrangChu" class="btn btn-dark btn-block btn-lg mt-4 font-weight-bold">
                QUAY VỀ TRANG CHỦ
            </a>
        </div>
    </div>
</div>
