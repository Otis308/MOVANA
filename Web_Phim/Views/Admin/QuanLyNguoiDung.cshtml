@model Web_Phim.Models.QuanLyNguoiDungTongHopViewModel

@{
    ViewBag.Title = "Quản Lý Người Dùng";
}

@* --- STYLE RIÊNG CHO VIEW NÀY ĐỂ ĐỒNG BỘ DARK MODE --- *@
<style>
    /* Card nền tối */
    .card-dark {
        background-color: #1b2530; /* Màu nền giống Header */
        border: 1px solid #2c3b4e;
        color: #e0e0e0;
    }

    /* Input tìm kiếm trong trang quản trị */
    .admin-search-input {
        background-color: #0f171e;
        border: 1px solid #444;
        color: #fff;
    }

        .admin-search-input:focus {
            background-color: #0f171e;
            color: #fff;
            border-color: #f5c518; /* Màu vàng Gold */
            box-shadow: none;
        }

    /* Table tối màu */
    .table-dark-custom {
        background-color: #1b2530;
        color: #ccc;
    }

        .table-dark-custom th {
            border-top: none;
            border-bottom: 2px solid #444;
            color: #f5c518; /* Tiêu đề cột màu vàng */
        }

        .table-dark-custom td {
            border-top: 1px solid #333;
            vertical-align: middle;
        }

    .table-hover tbody tr:hover {
        background-color: rgba(255,255,255,0.05); /* Hover sáng nhẹ */
    }
</style>

<div class="container-fluid mt-4 px-4">

    @* --- HEADER --- *@
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div class="d-flex align-items-center">
            <h2 class="text-white fw-bold mb-0" style="border-left: 5px solid #f5c518; padding-left: 15px;">
                <i class="fa fa-users-cog me-2"></i> Quản Lý Người Dùng
            </h2>

            <a href="@Url.Action("BaoCaoPhanHang", "Admin")"
               onclick="showLoadingGeneric()"
               class="btn btn-warning text-dark fw-bold shadow-sm ml-3">
                <i class=" mr-1"></i> Báo cáo phân hạng
            </a>
        </div>

        <div>
            <a href="@Url.Action("ThemNhanVien", "Admin")" class="btn btn-warning text-dark fw-bold shadow-sm">
                <i class=" mr-1"></i> Thêm Nhân Viên
            </a>
        </div>

    </div>

    @* --- THÔNG BÁO (ALERTS) --- *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="fa fa-check-circle me-2"></i> <strong> @TempData["SuccessMessage"] </strong> 
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="fa fa-exclamation-triangle me-2"></i> <strong>Lỗi!</strong> @TempData["ErrorMessage"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <div class="row">
        @* --- PHẦN 1: THỐNG KÊ (BÊN TRÁI) --- *@
        <div class="col-md-3 mb-5">
            <div class="card card-dark shadow-sm h-20">
                <div class="card-header border-bottom-0 pt-3">
                    <h5 class="card-title fw-bold text-warning mb-0"><i class=" me-2"></i>Thống Kê</h5>
                </div>
                <div class="card-body">
                    <table class="table table-dark-custom mb-0 w-100">
                        <thead>
                            <tr>
                                <th>Nhóm Quyền</th>
                                <th class="text-center">Số Lượng</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.ThongKeTheoQuyen)
                            {
                                <tr>
                                    <td>
                                        @if (item.TenNhomQuyen == "Admin")
                                        {
                                            <span class="badge badge-danger">@item.TenNhomQuyen</span> @* Màu đỏ *@
                                        }
                                        else if (item.TenNhomQuyen == "Staff")
                                        {
                                            <span class="badge badge-success">@item.TenNhomQuyen</span> @* <-- Màu Xanh Lá (Sửa chỗ này) *@
                                        }
                                        else
                                        {
                                            <span class="badge badge-primary">@item.TenNhomQuyen</span> @* Màu xanh dương cho Customer *@
                                        }
                                    </td>
                                    <td class="text-center fw-bold text-white">@item.SoLuongTaiKhoan</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>

        @* --- PHẦN 2: DANH SÁCH CHI TIẾT (BÊN PHẢI) --- *@
        <div class="col-md-9 mb-4">
            <div class="card card-dark shadow-sm">
                <div class="card-header border-bottom-0 pt-3 d-flex justify-content-between align-items-center">
                    <h5 class="card-title fw-bold text-warning mb-0"><i class=" me-2"></i>Danh Sách Tài Khoản</h5>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-dark-custom table-hover mb-0">
                            <thead>
                                <tr>
                                    <th class="pl-4">ID</th>
                                    <th>Tài Khoản</th>
                                    <th>Thông Tin Liên Hệ</th>
                                    <th>Quyền</th>
                                    <th class="text-center">Tác Vụ</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model.DanhSachChiTiet)
                                {
                                    <tr>
                                        <td class="pl-4 text-muted">@user.UserID</td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                    
                                                <div>
                                                    <div class="font-weight-bold text-white">@user.HoTen</div>
                                                    <small class="text-muted">@user.UserName</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div style="font-size: 0.9rem;">
                                                <div class="mb-1"><i class="fa fa-envelope text-secondary mr-2"></i>@user.Email</div>
                                                <div><i class="fa fa-phone text-secondary mr-2"></i>@(string.IsNullOrEmpty(user.SoDienThoai) ? "---" : user.SoDienThoai)</div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge @(user.TenNhomQuyen == "Admin" ? "badge-danger" : (user.TenNhomQuyen == "Staff" ? "badge-success" : "badge-info"))">
                                                @user.TenNhomQuyen
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            @if (user.TenNhomQuyen != "Admin")
                                            {
                                                <a href="@Url.Action("XoaUser", new { id = user.UserID })"
                                                   class="btn btn-outline-danger btn-sm"
                                                   title="Xóa">
                                                    <i class="fa fa-trash-alt"></i>
                                                </a>
                                            }
                                            else
                                            {
                                                <i class="fa fa-lock text-muted" title="Không thể xóa Admin"></i>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-top border-secondary text-right">
                    <small class="text-muted">Tổng: @Model.DanhSachChiTiet.Count() tài khoản</small>
                </div>
            </div>
        </div>
    </div>
</div>
<script>function showLoadingGeneric() {
        // Tạo một overlay đơn giản nếu chưa có
        if (!document.getElementById('loadingOverlay')) {
            var overlay = document.createElement('div');
            overlay.id = 'loadingOverlay';
            overlay.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(255,255,255,0.7);z-index:9999;display:flex;justify-content:center;align-items:center;';
            overlay.innerHTML = '<div class="spinner-border text-primary" style="width: 3rem; height: 3rem;"></div>';
            document.body.appendChild(overlay);
        }
    }</script>