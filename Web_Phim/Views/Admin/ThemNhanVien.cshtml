@model Web_Phim.Models.ThemNhanVienViewModel
@using System.Web.Optimization
@using System.Web.Mvc.Html

@{
    ViewBag.Title = "Thêm Nhân Viên Mới";
}

@section Styles {
    <style>
        /* --- GIAO DIỆN DARK MODE + WARNING --- */

        /* 1. Nền Card màu Xanh Đen Tối */
        .card-vip {
            background-color: #0f172a; /* Màu nền chính */
            color: #ffffff;
            border: 1px solid #334155;
            box-shadow: 0 10px 30px rgba(0,0,0,0.7); /* Bóng đổ đậm hơn cho ngầu */
        }

        /* 2. Header gạch chân vàng */
        .card-header-vip {
            border-bottom: 2px solid #ffc107;
            background-color: rgba(255, 193, 7, 0.05); /* Nền vàng mờ cực nhẹ ở header */
        }

        /* 3. Input Group & Form Control */
        .input-group-text {
            background-color: #1e293b;
            border: 1px solid #475569;
            color: #ffc107; /* Icon màu vàng */
        }

        .form-control {
            background-color: #1e293b;
            border: 1px solid #475569;
            color: #fff;
        }

            .form-control::placeholder {
                color: #64748b;
            }

            /* Focus: Viền vàng */
            .form-control:focus {
                background-color: #0f172a;
                color: #ffc107; /* Khi gõ chữ sẽ ra màu vàng luôn cho hợp tone */
                border-color: #ffc107;
                box-shadow: 0 0 0 0.2rem rgba(255, 193, 7, 0.25);
            }

        /* Input Group khi focus */
        .input-group:focus-within .input-group-text {
            border-color: #ffc107;
            text-shadow: 0 0 5px #ffc107; /* Hiệu ứng icon phát sáng nhẹ */
        }
    </style>
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card card-vip rounded-lg">

                <div class="card-header card-header-vip text-center py-4">
                    <h3 class="font-weight-bold mb-0 text-uppercase text-warning" style="letter-spacing: 2px;">
                        <i class="fa fa-user-plus mr-2"></i> @ViewBag.Title
                    </h3>
                </div>

                <div class="card-body p-5">
                    @using (Html.BeginForm("ThemNhanVien", "Admin", FormMethod.Post, new { @class = "form-horizontal" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "alert alert-warning text-dark font-weight-bold border-0" })

                        <input type="hidden" name="GroupID" value="2" />

                        @* ------------------- TÊN ĐĂNG NHẬP ------------------- *@
                        <div class="form-group mb-4">
                            @Html.LabelFor(model => model.UserName, htmlAttributes: new { @class = "control-label font-weight-bold ml-1 text-warning" })
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text"><i class="fa fa-user"></i></span>
                                </div>
                                @Html.EditorFor(model => model.UserName, new { htmlAttributes = new { @class = "form-control", @placeholder = "Nhập tên đăng nhập..." } })
                            </div>
                            @Html.ValidationMessageFor(model => model.UserName, "", new { @class = "text-danger small mt-1 font-italic" })
                        </div>

                        @* ------------------- MẬT KHẨU ------------------- *@
                        <div class="form-group mb-4">
                            @Html.LabelFor(model => model.Password, htmlAttributes: new { @class = "control-label font-weight-bold ml-1 text-warning" })
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text"><i class="fa fa-lock"></i></span>
                                </div>
                                @Html.PasswordFor(model => model.Password, new { @class = "form-control", @placeholder = "Nhập mật khẩu..." })
                            </div>
                            @Html.ValidationMessageFor(model => model.Password, "", new { @class = "text-danger small mt-1 font-italic" })
                        </div>

                        @* ------------------- HỌ TÊN ------------------- *@
                        <div class="form-group mb-4">
                            @Html.LabelFor(model => model.HoTen, htmlAttributes: new { @class = "control-label font-weight-bold ml-1 text-warning" })
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text"><i class="fa fa-id-card"></i></span>
                                </div>
                                @Html.EditorFor(model => model.HoTen, new { htmlAttributes = new { @class = "form-control", @placeholder = "Nhập họ và tên..." } })
                            </div>
                            @Html.ValidationMessageFor(model => model.HoTen, "", new { @class = "text-danger small mt-1 font-italic" })
                        </div>

                        <div class="row">
                            @* ------------------- EMAIL ------------------- *@
                            <div class="col-md-6 form-group mb-4">
                                @Html.LabelFor(model => model.Email, htmlAttributes: new { @class = "control-label font-weight-bold ml-1 text-warning" })
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text"><i class="fa fa-envelope"></i></span>
                                    </div>
                                    @Html.EditorFor(model => model.Email, new { htmlAttributes = new { @class = "form-control", @type = "email", @placeholder = "Email..." } })
                                </div>
                                @Html.ValidationMessageFor(model => model.Email, "", new { @class = "text-danger small mt-1 font-italic" })
                            </div>

                            @* ------------------- SỐ ĐIỆN THOẠI ------------------- *@
                            <div class="col-md-6 form-group mb-4">
                                @Html.LabelFor(model => model.SoDienThoai, htmlAttributes: new { @class = "control-label font-weight-bold ml-1 text-warning" })
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text"><i class="fa fa-phone"></i></span>
                                    </div>
                                    @Html.EditorFor(model => model.SoDienThoai, new { htmlAttributes = new { @class = "form-control", @type = "tel", @placeholder = "SĐT..." } })
                                </div>
                                @Html.ValidationMessageFor(model => model.SoDienThoai, "", new { @class = "text-danger small mt-1 font-italic" })
                            </div>
                        </div>

                        <hr style="border-top: 1px solid #334155;" class="my-4" />

                        @* ------------------- NÚT SUBMIT ------------------- *@
                        <div class="form-group mb-0 text-center">
                            <button type="submit" class="btn btn-warning btn-lg px-5 font-weight-bold shadow rounded-pill text-uppercase">
                                <i class="fa fa-check-circle mr-1"></i> Thêm Nhân Viên
                            </button>

                            <div class="mt-3">
                                <a href="@Url.Action("QuanLyNguoiDung", "Admin")" class="text-secondary text-decoration-none small">
                                    <i class="fa fa-arrow-left"></i> Quay lại danh sách
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}