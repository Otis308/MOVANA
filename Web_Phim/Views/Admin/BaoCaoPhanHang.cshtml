@model IEnumerable<Web_Phim.Models.BaoCaoChiTieuViewModel>

@{
    ViewBag.Title = "Báo Cáo Phân Hạng Khách Hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Định nghĩa màu vàng chủ đạo của Layout */
    :root {
        --movana-yellow: #f5c518;
        --movana-dark-bg: #1a1a1a; /* Màu nền tối cho card */
        --movana-darker-bg: #121212; /* Màu nền tối hơn cho header/footer */
        --movana-text-light: #e0e0e0;
    }

    /* 1. CẤU HÌNH MÀN HÌNH CHỜ (LOADING) - CHUYỂN SANG TỐI */
    #loadingOverlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        /* Nền đen mờ thay vì trắng mờ */
        background: rgba(0, 0, 0, 0.85);
        z-index: 9999;
        display: none; /* Mặc định ẩn */
        justify-content: center;
        align-items: center;
        flex-direction: column;
    }

    /* Spinner và text màu vàng */
    .spinner-border.text-movana-yellow {
        color: var(--movana-yellow) !important;
        width: 3rem;
        height: 3rem;
    }

    .loading-text {
        color: var(--movana-yellow);
        font-weight: bold;
    }

    .loading-subtext {
        color: var(--movana-text-light);
    }

    /* 2. CẤU HÌNH CARD & TABLE TỐI MÀU */
    .card-dark {
        background-color: var(--movana-dark-bg);
        border: 1px solid #333;
        color: var(--movana-text-light);
    }

    .card-header-dark {
        background-color: var(--movana-darker-bg);
        border-bottom: 1px solid #333;
    }

    .card-footer-dark {
        background-color: var(--movana-darker-bg);
        border-top: 1px solid #333;
    }

    /* Tùy chỉnh bảng tối màu */
    .table-dark-movana {
        background-color: var(--movana-dark-bg);
        color: var(--movana-text-light);
    }

        .table-dark-movana th, .table-dark-movana td {
            border-color: #333; /* Viền bảng màu tối */
            vertical-align: middle !important;
        }

        .table-dark-movana thead th {
            color: var(--movana-yellow); /* Tiêu đề cột màu vàng */
            background-color: var(--movana-darker-bg);
            border-bottom-width: 2px;
        }
    /* Hiệu ứng hover dòng trong bảng */
    .table-hover.table-dark-movana tbody tr:hover {
        background-color: rgba(245, 197, 24, 0.15); /* Màu vàng nhạt khi rê chuột */
    }

    /* 3. NÚT BẤM THEO THEME */
    .btn-movana-yellow {
        background-color: var(--movana-yellow);
        color: #000; /* Chữ đen trên nền vàng */
        font-weight: bold;
        border: none;
    }

        .btn-movana-yellow:hover {
            background-color: #e0b315; /* Vàng đậm hơn khi hover */
            color: #000;
        }

    .btn-outline-light-custom {
        border-color: #555;
        color: var(--movana-text-light);
    }

        .btn-outline-light-custom:hover {
            background-color: #333;
            color: #fff;
        }

    /* Màu text tùy chỉnh cho tên khách hàng trong bảng tối */
    .text-highlight-light {
        color: #fff;
        font-weight: 600;
    }
</style>

<div id="loadingOverlay">
    <div class="spinner-border text-movana-yellow" role="status">
        <span class="sr-only">Đang xử lý...</span>
    </div>
    <h5 class="mt-3 loading-text">Đang tổng hợp dữ liệu từ Cursor...</h5>
    <p class="loading-subtext">Vui lòng đợi trong giây lát</p>
</div>

<div class="container-fluid mt-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-warning font-weight-bold" style="border-left: 4px solid #f5c518; padding-left: 12px;">
            Báo Cáo Phân Hạng Khách Hàng
        </h1>

    </div>

    <div class="mb-3 text-right">
        <a href="@Url.Action("BaoCaoPhanHang", "Admin")" onclick="showLoading()" class="btn btn-movana-yellow btn-icon-split shadow-sm">
            <span class="icon text-dark-50">
                <i class="fas fa-sync-alt"></i>
            </span>
            <span class="text">Cập nhật dữ liệu mới nhất</span>
        </a>
    </div>

    <div class="card card-dark shadow mb-4">
        <div class="card-header card-header-dark py-3">
            <h6 class="m-0 font-weight-bold" style="color: var(--movana-yellow);">
                <i class="fas fa-chart-bar mr-2"></i> Thống Kê Chi Tiêu & Xếp Hạng (Sử dụng Cursor)
            </h6>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover table-dark table-dark-movana" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr class="text-center">
                            <th style="width: 5%">STT</th>
                            <th style="width: 25%">Họ và Tên</th>
                            <th style="width: 15%">Số Điện Thoại</th>
                            <th style="width: 20%">Tổng Chi Tiêu</th>
                            <th style="width: 20%">Hạng Thành Viên</th>

                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int stt = 1;
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center align-middle">@stt</td>
                                    <td class="text-highlight-light align-middle">@item.TenKhachHang</td>
                                    <td class="text-center align-middle">@item.SoDienThoai</td>
                                    <td class="text-right align-middle font-weight-bold" style="color: #2ecc71;">
                                        @string.Format("{0:N0} đ", item.TongTienDaChi)
                                    </td>
                                    <td class="text-center align-middle">
                                        @if (item.HangThanhVien.Contains("VIP"))
                                        {
                                            <span class="badge badge-danger px-3 py-2 w-75">
                                                <i class="fas fa-crown"></i> @item.HangThanhVien
                                            </span>
                                        }
                                        else if (item.HangThanhVien.Contains("THÂN THIẾT"))
                                        {
                                            /* Badge thân thiết màu vàng chữ đen cho dễ đọc */
                                            <span class="badge badge-warning px-3 py-2 w-75 text-dark" style="background-color: var(--movana-yellow); border: none;">
                                                <i class="fas fa-medal"></i> @item.HangThanhVien
                                            </span>
                                        }
                                        else
                                        {
                                            /* Badge thường màu xám nhạt chữ đen */
                                            <span class="badge badge-light px-3 py-2 w-75 text-dark">
                                                <i class="fas fa-user"></i> @item.HangThanhVien
                                            </span>
                                        }
                                    </td>

                                </tr>
                                stt++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <i class="fas fa-inbox fa-3x mb-3"></i><br />
                                    Chưa có dữ liệu thống kê nào.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
    <a href="@Url.Action("QuanLyNguoiDung", "Admin")" class="d-none d-sm-inline-block btn btn-sm btn-outline-light-custom shadow-sm">
        <i class="fas fa-arrow-left fa-sm"></i> Quay lại
    </a>
</div>

<script>
    function showLoading() {
        document.getElementById("loadingOverlay").style.display = "flex";
    }
</script>