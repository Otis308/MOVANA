@model Web_Phim.Models.User_

@{
    ViewBag.Title = "Xác Nhận Xóa Người Dùng";
}

@section Styles {
    <style>
        /* --- GIAO DIỆN DARK MODE (VIP) --- */
        .card-vip {
            background-color: #0f172a; /* Nền xanh tối */
            color: #ffffff;
            border: 1px solid #334155;
            box-shadow: 0 10px 30px rgba(0,0,0,0.7);
        }

        .card-header-vip {
            border-bottom: 2px solid #dc3545; /* Gạch chân màu Đỏ (Cảnh báo xóa) */
            background-color: rgba(220, 53, 69, 0.1); /* Nền đỏ rất mờ */
        }

        /* Nhãn thông tin màu Vàng */
        .label-custom {
            color: #ffc107;
            font-weight: bold;
            text-transform: uppercase;
            font-size: 0.9rem;
            letter-spacing: 1px;
        }

        /* Giá trị thông tin */
        .value-custom {
            color: #fff;
            font-size: 1.1rem;
            padding-left: 10px;
            border-left: 3px solid #334155; /* Đường kẻ dọc trang trí */
        }

        /* Icon thùng rác lớn */
        .icon-warning-big {
            font-size: 4rem;
            color: #dc3545; /* Màu đỏ */
            margin-bottom: 15px;
            animation: pulse 2s infinite; /* Hiệu ứng nhịp đập nhẹ */
        }

        @* Animation nhẹ *@
        @@keyframes pulse {
            0% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.05); opacity: 0.8; }
            100% { transform: scale(1); opacity: 1; }
        }
    </style>
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card card-vip rounded-lg text-center">

                <div class="card-header card-header-vip py-3">
                    <h4 class="font-weight-bold mb-0 text-warning text-uppercase">
                        @ViewBag.Title
                    </h4>
                </div>

                <div class="card-body p-4">
                    <div class="mb-3">
                        <i class="fas fa-exclamation-triangle icon-warning-big"></i>
                    </div>

                    <h5 class="text-white mb-4">
                        Bạn có chắc chắn muốn xóa tài khoản này không?
                        <br />
                        
                    </h5>

                    <div class="text-left bg-dark p-3 rounded border border-secondary mb-4" style="background-color: #1e293b !important;">
                        <div class="row mb-2">
                            <div class="col-5 text-right label-custom">Tên Đăng Nhập:</div>
                            <div class="col-7 value-custom">@Model.UserName</div>
                        </div>

                        <div class="row mb-2">
                            <div class="col-5 text-right label-custom">Họ Tên:</div>
                            <div class="col-7 value-custom">@Model.Name</div>
                        </div>

                        <div class="row mb-2">
                            <div class="col-5 text-right label-custom">ID Tài Khoản:</div>
                            <div class="col-7 value-custom">@Model.UserID</div>
                        </div>

                        
                    </div>

                    @using (Html.BeginForm("XoaUser", "Admin", new { id = Model.UserID }, FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()

                        <div class="d-flex justify-content-center">
                            <button type="submit" class="btn btn-danger btn-lg px-4 font-weight-bold shadow rounded-pill mr-3">
                                <i class="fa fa-trash-alt mr-2"></i> XÁC NHẬN XÓA
                            </button>

                            @Html.ActionLink("Hủy Bỏ", "QuanLyNguoiDung", null, new { @class = "btn btn-outline-secondary btn-lg px-4 font-weight-bold rounded-pill" })
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>